#include <iostream>
using namespace std;

class Student
{
private:
    int id;
    string name;

public:

    Student(int i, string n)
    {
        id = i;
        name = n;
    }


    Student(const Student &s)
    {
        id = s.id;
        name = s.name;
    }

    void display()
    {
        cout << "ID: " << id << " Name: " << name << endl;
    }
};

int main()
{
    Student s1(101, "fritha");
    Student s2 = s1;


    s1.display();
    s2.display();

    return 0;
}
