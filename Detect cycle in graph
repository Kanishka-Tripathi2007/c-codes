#include <bits/stdc++.h>
using namespace std;

bool dfs(int node,int parent,vector<vector<int>>& adj,vector<int>& vis){
    vis[node]=1;

    for(int nxt:adj[node]){
        if(!vis[nxt]){
            if(dfs(nxt,node,adj,vis)) return true;
        }
        else if(nxt!=parent)
            return true;
    }
    return false;
}
