#include <bits/stdc++.h>
using namespace std;

bool pairSum(vector<int>& arr,int target){
    sort(arr.begin(),arr.end());

    int l=0,r=arr.size()-1;

    while(l<r){
        int sum=arr[l]+arr[r];
        if(sum==target) return true;
        else if(sum<target) l++;
        else r--;
    }
    return false;
}
