#include <iostream>
using namespace std;

class Student {
private:
    int marks;

public:
    void setMarks(int m) {
        marks = m;
    }

    void displayMarks() {
        cout << "Marks: " << marks << endl;
    }
};

int main() {
    Student s;

    // s.marks = 90; // Error: marks is private

    s.setMarks(90);
    s.displayMarks();

    return 0;
}
