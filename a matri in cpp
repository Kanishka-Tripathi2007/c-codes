
#include <iostream>
#include <windows.h>
#include <ctime>

using namespace std;

int main() {
    HANDLE hConsole = GetStdHandle(STD_OUTPUT_HANDLE);

    const int width = 80;
    const int height = 25;

    srand(time(0));

    while (true) {
        for (int i = 0; i < 100; i++) {

            int x = rand() % width;
            int y = rand() % height;

            SetConsoleCursorPosition(hConsole, { (SHORT)x, (SHORT)y });

            SetConsoleTextAttribute(hConsole, 10);

            char ch = 33 + rand() % 94;
            cout << ch;
        }

        Sleep(50);
    }

    return 0;
}
