
#include <iostream>
#include <cstdlib>
#include <ctime>

using namespace std;

int main() {
    string chars =
        "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
        "abcdefghijklmnopqrstuvwxyz"
        "0123456789!@#$%^&*";

    int length = 12;
    string password = "";

    srand(time(0));

    for(int i = 0; i < length; i++) {
        password += chars[rand() % chars.size()];
    }

    cout << "Generated Password: " << password << endl;

    return 0;
}
