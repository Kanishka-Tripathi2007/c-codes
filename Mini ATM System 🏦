#include <iostream>

using namespace std;

int main() {
    int balance = 5000;
    int choice, amount;

    do {
        cout << "\nATM MENU\n";
        cout << "1. Check Balance\n";
        cout << "2. Deposit\n";
        cout << "3. Withdraw\n";
        cout << "4. Exit\n";

        cin >> choice;

        switch(choice) {
            case 1:
                cout << "Balance: " << balance << endl;
                break;

            case 2:
                cout << "Enter amount: ";
                cin >> amount;
                balance += amount;
                break;

            case 3:
                cout << "Enter amount: ";
                cin >> amount;

                if(amount <= balance) {
                    balance -= amount;
                } else {
                    cout << "Insufficient Balance\n";
                }
                break;
        }

    } while(choice != 4);

    return 0;
}
